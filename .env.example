# Copy file ini menjadi .env di VPS:
# cp .env.example .env

# Port luar VPS. Container tetap berjalan di port internal 4099.
APP_PORT=3084
PORT=4099

# URL function collect-event dari web admin.
# Contoh Netlify admin:
# ADMIN_COLLECT_ENDPOINT=https://NAMA-WEB-ADMIN.netlify.app/.netlify/functions/collect-event
ADMIN_COLLECT_ENDPOINT=https://NAMA-WEB-ADMIN.netlify.app/.netlify/functions/collect-event

# Secret sama persis dengan ADMIN_INGEST_SECRET di web admin.
ADMIN_INGEST_SECRET=buat-secret-random-yang-sama
